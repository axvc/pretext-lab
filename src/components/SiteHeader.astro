---
const links = [
  { href: "/#experiments", label: "Experiments", active: true },
  { href: "/methodology", label: "Methodology", active: false },
  { href: "https://github.com/axvc/pretext-lab", label: "GitHub", external: true, active: false },
];
---

<header>
  <div class="flex items-center justify-between px-6 lg:px-24 py-4">
    <a href="/" class="flex items-center gap-2 font-mono text-sm text-[var(--color-fg)] hover:no-underline">
      <span class="inline-block w-[6px] h-[6px] rounded-[2px] bg-[var(--color-accent)] shrink-0"></span>
      pretext.lab
    </a>
    <nav class="flex items-center gap-8 font-mono text-sm">
      {
        links.map((link) => (
          <a
            href={link.href}
            target={link.external ? "_blank" : undefined}
            rel={link.external ? "noopener noreferrer" : undefined}
            class:list={[
              "hover:no-underline transition-colors",
              link.active ? "text-[var(--color-fg)]" : "text-[var(--color-muted)] hover:text-[var(--color-fg)]",
            ]}
          >
            {link.label}
          </a>
        ))
      }
    </nav>
  </div>
</header>
