---
import type { LineChartProps, LineStyle, SeriesPoint } from "./types";
import {
  logTicks,
  makeScale,
  paddedLinearDomain,
  paddedLogDomain,
} from "./lib/scale";

type Props = LineChartProps;

const {
  series,
  xScale,
  yScale,
  xLabel,
  yLabel,
  title,
  showYAxisLabels = true,
  xDomain: explicitXDomain,
  yDomain: explicitYDomain,
  xTicks,
  yTicks,
  width = 720,
  height = 420,
  annotations = [],
} = Astro.props;

const PAD = { top: 24, right: 28, bottom: 56, left: 76 } as const;
const plotW = width - PAD.left - PAD.right;
const plotH = height - PAD.top - PAD.bottom;

const allX = series.flatMap((s) => s.points.map((p) => p.x));
const allY = series.flatMap((s) => s.points.map((p) => p.y));

function domainFromTicks(ticks: number[]): [number, number] {
  return [Math.min(...ticks), Math.max(...ticks)];
}

function defaultDomain(values: number[], type: "linear" | "log"): [number, number] {
  return type === "log" ? paddedLogDomain(values) : paddedLinearDomain(values);
}

const xDomain: [number, number] =
  explicitXDomain ??
  (xTicks && xTicks.length > 0 ? domainFromTicks(xTicks) : defaultDomain(allX, xScale));

const yDomain: [number, number] =
  explicitYDomain ??
  (yTicks && yTicks.length > 0 ? domainFromTicks(yTicks) : defaultDomain(allY, yScale));

const xs = makeScale(xScale, xDomain, [PAD.left, PAD.left + plotW]);
const ys = makeScale(yScale, yDomain, [PAD.top + plotH, PAD.top]);

const xTickValues = xTicks ?? (xScale === "log" ? logTicks(xDomain) : []);
const yTickValues = yTicks ?? (yScale === "log" ? logTicks(yDomain) : []);
const ariaLabel = title ? `${title}: ${yLabel} vs ${xLabel}` : `${yLabel} vs ${xLabel}`;

function formatTick(value: number): string {
  const abs = Math.abs(value);
  if (abs === 0) return "0";
  const exp = Math.log10(abs);
  if (Number.isInteger(exp)) {
    if (exp >= 0 && exp <= 3) return String(10 ** exp);
    if (exp === 4) return "10k";
    if (exp === 5) return "100k";
    if (exp === 6) return "1M";
    return `10^${exp}`;
  }
  if (abs >= 100) return value.toFixed(0);
  if (abs >= 10) return value.toFixed(1);
  return value.toPrecision(2);
}

function pathFor(points: SeriesPoint[]): string {
  return points
    .map(
      (p, i) =>
        `${i === 0 ? "M" : "L"} ${xs(p.x).toFixed(2)} ${ys(p.y).toFixed(2)}`,
    )
    .join(" ");
}

function dashArray(style: LineStyle): string | undefined {
  if (style === "dashed") return "6 4";
  if (style === "dotted") return "1 5";
  return undefined;
}
---

<svg
  class="line-chart"
  viewBox={`0 0 ${width} ${height}`}
  role="img"
  aria-label={ariaLabel}
  preserveAspectRatio="xMidYMid meet"
>
  {
    title && (
      <text
        x={PAD.left + plotW / 2}
        y={14}
        text-anchor="middle"
        fill="var(--color-fg)"
        class="line-chart__title"
      >
        {title}
      </text>
    )
  }

  <g class="line-chart__grid">
    {
      yTickValues.map((v) => (
        <line
          x1={PAD.left}
          x2={width - PAD.right}
          y1={ys(v)}
          y2={ys(v)}
        />
      ))
    }
    {
      xTickValues.map((v) => (
        <line
          y1={PAD.top}
          y2={height - PAD.bottom}
          x1={xs(v)}
          x2={xs(v)}
        />
      ))
    }
  </g>

  <g class="line-chart__axis">
    <line
      x1={PAD.left}
      x2={width - PAD.right}
      y1={height - PAD.bottom}
      y2={height - PAD.bottom}
    />
    <line
      x1={PAD.left}
      x2={PAD.left}
      y1={PAD.top}
      y2={height - PAD.bottom}
    />
  </g>

  <g class="line-chart__ticks">
    {
      xTickValues.map((v) => (
        <g>
          <line
            x1={xs(v)}
            x2={xs(v)}
            y1={height - PAD.bottom}
            y2={height - PAD.bottom + 4}
          />
          <text
            x={xs(v)}
            y={height - PAD.bottom + 18}
            text-anchor="middle"
            class="line-chart__tick-label"
          >
            {formatTick(v)}
          </text>
        </g>
      ))
    }
    {
      yTickValues.map((v) => (
        <g>
          <line x1={PAD.left - 4} x2={PAD.left} y1={ys(v)} y2={ys(v)} />
          {
            showYAxisLabels && (
              <text
                x={PAD.left - 8}
                y={ys(v)}
                text-anchor="end"
                dominant-baseline="central"
                class="line-chart__tick-label"
              >
                {formatTick(v)}
              </text>
            )
          }
        </g>
      ))
    }
  </g>

  <text
    x={PAD.left + plotW / 2}
    y={height - 10}
    text-anchor="middle"
    class="line-chart__axis-label"
  >
    {xLabel}
  </text>
  {
    showYAxisLabels && (
      <text
        transform={`translate(20 ${PAD.top + plotH / 2}) rotate(-90)`}
        text-anchor="middle"
        class="line-chart__axis-label"
      >
        {yLabel}
      </text>
    )
  }

  <g class="line-chart__series">
    {
      series.map((s) => (
        <path
          d={pathFor(s.points)}
          stroke={s.color}
          stroke-width={s.strokeWidth ?? 1.5}
          stroke-dasharray={dashArray(s.lineStyle)}
          fill="none"
          stroke-linejoin="round"
          stroke-linecap="round"
          data-series-id={s.id}
        >
          <title>{s.label}</title>
        </path>
      ))
    }
  </g>

  <g class="line-chart__annotations">
    {
      annotations.map((a) => (
        <g>
          <circle
            cx={xs(a.x)}
            cy={ys(a.y)}
            r={3.5}
            fill={a.color ?? "var(--color-accent)"}
          />
          <text
            x={xs(a.x) + 8}
            y={ys(a.y) - 8}
            class="line-chart__annotation-label"
            fill={a.color ?? "var(--color-accent)"}
          >
            {a.label}
          </text>
        </g>
      ))
    }
  </g>
</svg>

<style>
  .line-chart {
    display: block;
    width: 100%;
    height: auto;
    max-width: 100%;
  }

  .line-chart__grid line {
    stroke: var(--color-border);
    stroke-width: 0.5;
  }

  .line-chart__axis line,
  .line-chart__ticks line {
    stroke: var(--color-dim);
    stroke-width: 1;
  }

  .line-chart__tick-label {
    font-family: var(--font-mono);
    font-size: 11px;
    font-feature-settings: "tnum" 1;
    fill: var(--color-muted);
  }

  .line-chart__title {
    font-family: var(--font-serif);
    font-size: 15px;
    font-weight: 600;
    font-variation-settings: "SOFT" 0, "WONK" 1;
    fill: var(--color-fg);
  }

  .line-chart__axis-label {
    font-family: var(--font-mono);
    font-size: 12px;
    fill: var(--color-fg);
  }

  .line-chart__annotation-label {
    font-family: var(--font-mono);
    font-size: 11px;
    font-feature-settings: "tnum" 1;
  }
</style>
