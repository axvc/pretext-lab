---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import ExperimentCard from "@/components/ExperimentCard.astro";

const experiments = (await getCollection("experiments")).sort(
  (a, b) => a.data.order - b.data.order,
);

const publishedCount = experiments.filter((e) => e.data.status === "published").length;
const countLabel = `${publishedCount} published · more in progress`;
---

<BaseLayout
  title="Pretext.lab"
  description="A public benchmarking lab for JavaScript text-layout strategies — DOM, Canvas, Pretext.js — measured across browser engines with rigorous methodology and reproducible numbers."
>
  <!-- Hero -->
  <section class="px-6 lg:px-24 pt-24 lg:pt-32 pb-24">
    <p class="font-mono text-[11px] uppercase tracking-[1.6px] text-[var(--color-muted)] mb-6">
      Research lab · Open source
    </p>

    <h1
      class="font-serif text-[48px] md:text-[64px] lg:text-[72px] leading-[1.05] tracking-[-0.02em] text-[var(--color-fg)] max-w-[800px] mb-8"
      style="font-variation-settings: 'SOFT' 0, 'WONK' 1"
    >
      Measuring the cost of text layout in the browser.
    </h1>

    <hr class="border-0 border-t border-[var(--color-border)] w-[280px] mb-8" />

    <p class="font-mono text-[14px] leading-[1.6] text-[var(--color-muted)] max-w-[580px] mb-10">
      A public benchmarking lab for JavaScript text-layout strategies — DOM, Canvas, Pretext.js —
      measured across browser engines with rigorous methodology and reproducible numbers.
    </p>

    <div class="flex flex-wrap gap-4">
      <a
        href="/#experiments"
        class="cta-primary border border-[var(--color-fg)] px-4 py-3 font-mono text-[14px] text-[var(--color-fg)]"
      >
        [ View experiments → ]
      </a>
      <a
        href="/methodology"
        class="cta-secondary border border-[var(--color-border)] px-4 py-3 font-mono text-[14px] text-[var(--color-muted)]"
      >
        [ Methodology ]
      </a>
    </div>
  </section>

  <!-- Experiments index -->
  <section id="experiments" class="px-6 lg:px-24 pb-32">
    <h2
      class="font-serif text-[40px] lg:text-[48px] leading-[1.05] tracking-[-0.02em] text-[var(--color-fg)] mb-3"
      style="font-variation-settings: 'SOFT' 0, 'WONK' 1"
    >
      Experiments
    </h2>
    <p class="font-mono text-[14px] text-[var(--color-muted)] mb-6">
      {countLabel}
    </p>

    <hr class="border-0 border-t border-[var(--color-border)] mb-0" />

    {
      experiments.length === 0 ? (
        <div
          class="mt-8 rounded-[8px]"
          style="background: var(--color-surface); border: 1px solid var(--color-border);"
        >
          <div class="px-5 pt-5">
            <h3
              class="font-serif text-[28px] leading-[1.05] tracking-[-0.01em] text-[var(--color-fg)]"
              style="font-variation-settings: 'SOFT' 0, 'WONK' 1"
            >
              Experiments
            </h3>
            <p class="font-mono text-[12px] text-[var(--color-muted)] mt-2">00 published</p>
          </div>
          <hr class="border-0 border-t border-[var(--color-border)] mt-5" />
          <div class="flex flex-col items-center gap-3 py-8 px-5 text-center">
            <p class="font-mono text-[14px] text-[var(--color-muted)]">
              No experiments published yet.
            </p>
            <p class="font-mono text-[12px] text-[var(--color-dim)]">
              <a href="/methodology" class="underline underline-offset-2">Methodology page</a> describes the planned experiments.
            </p>
          </div>
        </div>
      ) : (
        <div>
          {experiments.map((entry) => (
            <ExperimentCard
              href={`/experiments/${entry.id}`}
              order={entry.data.order}
              title={entry.data.title}
              summary={entry.data.summary}
              status={entry.data.status}
              apis={entry.data.apis}
              publishedDate={entry.data.publishedDate}
              quote={entry.data.quote}
              detail={entry.data.detail}
            />
          ))}
        </div>
      )
    }
  </section>
</BaseLayout>
