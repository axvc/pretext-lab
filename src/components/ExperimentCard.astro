---
type Props = {
  href?: string;
  order: number;
  title: string;
  summary: string;
  status: "draft" | "published" | "planned";
  apis: string[];
  publishedDate?: string;
  quote?: string;
  detail?: string;
};

const { href, order, title, summary, status, publishedDate, quote, detail } = Astro.props;

const orderLabel = `Experiment ${String(order).padStart(2, "0")}`;

let captionSuffix = "";
if (status === "published" && publishedDate) {
  captionSuffix = `· Published ${publishedDate}`;
} else if (status === "draft") {
  captionSuffix = "· In progress";
} else if (status === "planned") {
  captionSuffix = "· Planned";
}

const titleColor =
  status === "published"
    ? "text-[var(--color-fg)]"
    : status === "draft"
      ? "text-[var(--color-muted)]"
      : "text-[var(--color-dim)]";

const quoteColor =
  status === "published" ? "text-[var(--color-muted)]" : "text-[var(--color-dim)]";
---

<div class="border-b border-[var(--color-border)] py-8 flex gap-12">
  <!-- Left column -->
  <div class="w-[360px] shrink-0 flex flex-col gap-3">
    <p class="font-mono text-[11px] uppercase tracking-[1.6px] text-[var(--color-dim)]">
      {orderLabel} {captionSuffix}
    </p>
    <h3
      class:list={[
        "font-serif text-[28px] leading-[1.15] tracking-[-0.01em]",
        titleColor,
      ]}
      style="font-variation-settings: 'SOFT' 0, 'WONK' 1"
    >
      {title}
    </h3>
    {
      detail && (
        <p class:list={["font-mono text-[13px]", status === "published" ? "text-[var(--color-muted)]" : "text-[var(--color-dim)]"]}>
          {detail}
        </p>
      )
    }
    {
      !detail && (
        <p class:list={["font-mono text-[13px]", status === "published" ? "text-[var(--color-muted)]" : "text-[var(--color-dim)]"]}>
          {summary}
        </p>
      )
    }
  </div>

  <!-- Right column -->
  <div class="flex-1 flex flex-col justify-between gap-8">
    {
      quote && (
        <p class:list={["font-mono text-[13px] leading-[1.55] max-w-[560px]", quoteColor]}>
          "{quote}"
        </p>
      )
    }
    {
      !quote && (
        <p class:list={["font-mono text-[13px] leading-[1.55] max-w-[560px]", quoteColor]}>
          {summary}
        </p>
      )
    }

    <div class="flex gap-3">
      {
        status === "published" && href ? (
          <>
            <a
              href={href}
              class="border border-[var(--color-fg)] px-[14px] py-[10px] font-mono text-[13px] text-[var(--color-fg)] hover:no-underline hover:opacity-70 transition-opacity"
            >
              [ Read article → ]
            </a>
            <a
              href={`${href}#bench`}
              class="border border-[var(--color-fg)] px-[14px] py-[10px] font-mono text-[13px] text-[var(--color-fg)] hover:no-underline hover:opacity-70 transition-opacity"
            >
              [ Run benchmark → ]
            </a>
          </>
        ) : status === "draft" ? (
          <span class="font-mono text-[12px] text-[var(--color-dim)]">[ in progress ]</span>
        ) : (
          <span class="font-mono text-[12px] text-[var(--color-dim)]">[ planned ]</span>
        )
      }
    </div>
  </div>
</div>
