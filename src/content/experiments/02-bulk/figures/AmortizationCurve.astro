---
import LineChart from "@/components/charts/LineChart.astro";
import type { Annotation, Series } from "@/components/charts/types";

// MOCK — replace with AXV-528 output
const N_VALUES = [10, 30, 100, 300, 1000, 3000, 10_000] as const;
const X_DOMAIN: [number, number] = [10, 10_000];
const Y_DOMAIN: [number, number] = [1, 1000];

type Browser = "Chrome" | "Firefox" | "Safari";
type Strategy = "DOM" | "Canvas" | "Pretext";

const BROWSERS: readonly Browser[] = ["Chrome", "Firefox", "Safari"] as const;
const STRATEGIES: readonly Strategy[] = ["DOM", "Canvas", "Pretext"] as const;

// Browser colors are intentionally overridden here: browser is panel identity,
// while strategy is the primary comparison axis inside each panel.
const STRATEGY_COLOR: Record<Strategy, string> = {
  DOM: "var(--color-muted)",
  Canvas: "#d9c8a8",
  Pretext: "var(--color-accent)",
};

const BREAKEVEN_N: Record<Browser, number> = {
  Chrome: 128,
  Firefox: 134,
  Safari: 141,
};

// Cost model per (strategy, browser): per-paragraph cost (µs) = bulk / N + perItem.
const COST_MODEL: Record<
  Strategy,
  Record<Browser, { bulk: number; perItem: number }>
> = {
  DOM: {
    Chrome: { bulk: 200, perItem: 25 },
    Firefox: { bulk: 220, perItem: 28 },
    Safari: { bulk: 280, perItem: 35 },
  },
  Canvas: {
    Chrome: { bulk: 1000, perItem: 15 },
    Firefox: { bulk: 1200, perItem: 18 },
    Safari: { bulk: 800, perItem: 14 },
  },
  Pretext: {
    Chrome: { bulk: 3000, perItem: 3 },
    Firefox: { bulk: 3500, perItem: 3.5 },
    Safari: { bulk: 4500, perItem: 5 },
  },
};

function costAt(strategy: Strategy, browser: Browser, n: number): number {
  const { bulk, perItem } = COST_MODEL[strategy][browser];
  return bulk / n + perItem;
}

const panels = BROWSERS.map((browser) => {
  const breakevenN = BREAKEVEN_N[browser];
  const series: Series[] = STRATEGIES.map((strategy) => ({
    id: `${browser}-${strategy}`,
    label: strategy,
    color: STRATEGY_COLOR[strategy],
    lineStyle: "solid",
    strokeWidth: 2,
    points: N_VALUES.map((n) => ({ x: n, y: costAt(strategy, browser, n) })),
  }));
  const annotations: Annotation[] = [
    {
      x: breakevenN,
      y: costAt("Pretext", browser, breakevenN),
      label: `N = ${breakevenN}`,
      color: "var(--color-accent)",
    },
  ];

  return { browser, series, annotations };
});

const legendItems = STRATEGIES.map((strategy) => ({
  label: strategy,
  color: STRATEGY_COLOR[strategy],
}));
---

<figure class="amortization-curve">
  <div class="amortization-curve__legend" aria-label="Strategy legend">
    {
      legendItems.map((item) => (
        <div class="amortization-curve__legend-item">
          <span
            class="amortization-curve__legend-swatch"
            style={`--swatch-color: ${item.color}`}
          />
          <span>{item.label}</span>
        </div>
      ))
    }
  </div>

  <div class="amortization-curve__panels">
    {
      panels.map((panel, index) => (
        <div class="amortization-curve__panel">
          <LineChart
            title={panel.browser}
            series={panel.series}
            xScale="log"
            yScale="log"
            xLabel="N (paragraphs)"
            yLabel="per-paragraph cost (µs)"
            xDomain={X_DOMAIN}
            yDomain={Y_DOMAIN}
            xTicks={[10, 100, 1000, 10_000]}
            annotations={panel.annotations}
            showYAxisLabels={index === 0}
            width={220}
            height={300}
          />
        </div>
      ))
    }
  </div>
</figure>

<style>
  .amortization-curve {
    margin: 1.5rem 0 2.5rem;
    width: 100%;
  }

  .amortization-curve__legend {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 18px;
    margin-bottom: 18px;
    font-family: var(--font-mono);
    font-size: 12px;
    line-height: 1;
    color: var(--color-muted);
  }

  .amortization-curve__legend-item {
    display: inline-flex;
    align-items: center;
    gap: 7px;
  }

  .amortization-curve__legend-swatch {
    display: inline-block;
    width: 28px;
    height: 0;
    border-top: 2px solid var(--swatch-color);
  }

  .amortization-curve__panels {
    display: flex;
    gap: 24px;
    width: 100%;
  }

  .amortization-curve__panel {
    flex: 1 1 0;
    min-width: 0;
  }
</style>
