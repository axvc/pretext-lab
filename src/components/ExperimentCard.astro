---
type Props = {
  href?: string;
  order: number;
  title: string;
  summary: string;
  status: "draft" | "published";
  apis: string[];
};

const { href, order, title, summary, status, apis } = Astro.props;
const isDraft = status === "draft";
const Wrapper = isDraft ? "div" : "a";
const wrapperProps = isDraft ? {} : { href };
---

<Wrapper
  {...wrapperProps}
  class:list={[
    "block border border-[var(--color-border)] rounded-lg p-6 transition-colors",
    isDraft
      ? "opacity-60 cursor-default"
      : "hover:border-[var(--color-accent)] hover:no-underline",
  ]}
>
  <div class="flex items-baseline justify-between mb-3">
    <span class="font-mono text-xs uppercase tracking-wider text-[var(--color-muted)]">
      #{String(order).padStart(2, "0")}
    </span>
    {
      isDraft && (
        <span class="font-mono text-xs uppercase tracking-wider text-[var(--color-accent)]">
          coming soon
        </span>
      )
    }
  </div>
  <h3 class="text-lg font-semibold mb-2">{title}</h3>
  <p class="text-sm text-[var(--color-muted)] mb-4">{summary}</p>
  {
    apis.length > 0 && (
      <ul class="flex flex-wrap gap-2">
        {apis.map((api) => (
          <li class="font-mono text-xs px-2 py-0.5 rounded border border-[var(--color-border)] text-[var(--color-muted)]">
            {api}
          </li>
        ))}
      </ul>
    )
  }
</Wrapper>
